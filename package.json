{
  "name": "authula",
  "type": "module",
  "version": "0.5.1",
  "description": "Official SDK for Authula.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Authula/authula-node-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Authula/authula-node-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Authula/authula-node-sdk/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "require": "./dist/plugins/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "cookie": "^1.1.1",
    "es-toolkit": "^1.46.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "bumpp": "^11.0.1",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
